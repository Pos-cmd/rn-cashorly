{
  "name": "rn-cashory",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "better-auth": "1.6.11",
      "@better-auth/expo": "1.6.11"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @rn-cashory/db db:push",
    "db:studio": "turbo -F @rn-cashory/db db:studio",
    "db:generate": "turbo -F @rn-cashory/db db:generate",
    "db:migrate": "turbo -F @rn-cashory/db db:migrate"
  },
  "dependencies": {
    "@rn-cashory/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rn-cashory/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.2"
}
